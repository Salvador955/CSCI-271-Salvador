#include <iostream>
#include <limits>
#include <string>
using namespace std;

int main() {

    double score[3][3];
    string courseName[3] = {"Math", "C Programming", "Operating Systems"};

    bool hasData = false;
    int choice;

    do {
        cout << "\n=== Student Grade System ===\n";
        cout << "1) Record grades (3x3)\n";
        cout << "2) One student's Total & Average\n";
        cout << "3) Display ALL (table + per-student stats)\n";
        cout << "4) Exit\n";
        cout << "Enter choice:";

        if (!(cin >> choice)) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "Invalid input. Try again.\n";
            continue;
        }

        // OPTION 1
        if (choice == 1) {

            for (int i = 0; i < 3; i++) {
                cout << "\nEntering grades for Student " << i << endl;

                for (int j = 0; j < 3; j++) {

                    while (true) {
                        cout << "Enter " << courseName[j] << " grade (0-100):";
                        cin >> score[i][j];

                        if (!cin) {
                            cin.clear();
                            cin.ignore(numeric_limits<streamsize>::max(), '\n');
                            cout << "Invalid input. Try again.\n";
                            continue;
                        }

                        if (score[i][j] < 0 || score[i][j] > 100) {
                            cout << "Grade must be between 0 and 100. Try again.\n";
                        }
                        else {
                            break;
                        }
                    }
                }
            }

            hasData = true;
            cout << "\nAll grades recorded successfully!\n";
        }

        // OPTION 2
        else if (choice == 2) {

            if (!hasData) {
                cout << "Please record grades first (option 1).\n";
                continue;
            }

            int idx;
            cout << "Enter student index (0-2):";
            cin >> idx;

            if (!cin || idx < 0 || idx > 2) {
                cin.clear();
                cin.ignore(numeric_limits<streamsize>::max(), '\n');
                cout << "Invalid student index.\n";
                continue;
            }

            double total = 0;

            cout << "\nStudent " << idx << " Grades:\n";

            for (int j = 0; j < 3; j++) {
                cout << courseName[j] << ":" << score[idx][j] << endl;
                total += score[idx][j];
            }

            double average = total / 3.0;

            cout << "Total:" << total << endl;
            cout << "Average:" << average << endl;
        }

        // OPTION 3
        else if (choice == 3) {

            if (!hasData) {
                cout << "Please record grades first (option 1).\n";
                continue;
            }

            cout << "\n=== Grade Table ===\n";
            cout << "        Math   C Prog   OS\n";

            for (int i = 0; i < 3; i++) {

                cout << "S" << i << "      ";
                double total = 0;

                for (int j = 0; j < 3; j++) {
                    cout << score[i][j] << "      ";
                    total += score[i][j];
                }

                double average = total / 3.0;

                cout << "\n   Total:" << total
                     << " Average:" << average << "\n\n";
            }
        }

        // EXIT
        else if (choice == 4) {
            cout << "Bye!\n";
        }

        else {
            cout << "Invalid choice. Enter 1, 2, 3, or 4.\n";
        }

    } while (choice != 4);

    return 0;
}
